{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Segoe UI, -apple-system, sans-serif",
    "fontSize": "16px",
    "primaryColor": "#DEECF9",
    "primaryTextColor": "#0B2545",
    "primaryBorderColor": "#0078D4",
    "lineColor": "#005A9E",
    "secondaryColor": "#FFFFFF",
    "tertiaryColor": "#F3F9FD",
    "background": "#FFFFFF",
    "mainBkg": "#DEECF9",
    "secondBkg": "#FFFFFF",
    "tertiaryBkg": "#F3F9FD",
    "clusterBkg": "#F3F9FD",
    "clusterBorder": "#0078D4",
    "edgeLabelBackground": "#FFFFFF",
    "nodeBorder": "#0078D4",
    "actorBkg": "#DEECF9",
    "actorBorder": "#0078D4",
    "actorTextColor": "#0B2545",
    "actorLineColor": "#005A9E",
    "signalColor": "#005A9E",
    "signalTextColor": "#0B2545",
    "labelBoxBkgColor": "#DEECF9",
    "labelBoxBorderColor": "#0078D4",
    "labelTextColor": "#0B2545",
    "loopTextColor": "#0B2545",
    "noteBkgColor": "#FFF4CE",
    "noteBorderColor": "#8A8886",
    "noteTextColor": "#1B1B1B",
    "activationBkgColor": "#0078D4",
    "activationBorderColor": "#005A9E"
  },
  "flowchart": {
    "curve": "basis",
    "padding": 20,
    "nodeSpacing": 50,
    "rankSpacing": 60,
    "htmlLabels": true
  },
  "sequence": {
    "actorMargin": 60,
    "messageMargin": 40,
    "boxMargin": 12,
    "noteMargin": 12,
    "mirrorActors": false
  }
}
